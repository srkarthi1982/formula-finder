---
interface Props {
  appName?: string;
  appKey?: string;
}

const { appName = "Formula Finder", appKey = "formula-finder" } = Astro.props;
const rootAppUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
const userName = Astro.locals.user?.name ?? Astro.locals.user?.email ?? "Member";
---

<header class="border-b border-white/10 bg-slate-950/70 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/app" class="text-sm font-semibold tracking-wide text-white">{appName}</a>
    <div class="flex items-center gap-4 text-xs text-slate-300">
      <span class="rounded-full bg-white/10 px-2 py-1">{appKey}</span>
      <span>{userName}</span>
      <a href={rootAppUrl} class="text-slate-200 hover:text-white">Ansiversa</a>
    </div>
  </div>
</header>
