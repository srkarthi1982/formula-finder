---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";

const title = "Formula Finder | Ansiversa";
const description = "Organize formulas by subject and topic with a premium, focused reference workspace.";
---

<AppShell title={title} description={description}>
  <section class="border-b border-white/10">
    <AvContainer size="narrow" className="py-20">
      <p class="mb-4 text-sm uppercase tracking-[0.2em] text-sky-300">Ansiversa · Learning Workspace</p>
      <h1 class="mb-6 text-4xl font-semibold leading-tight text-white sm:text-6xl">Your personal formula library, finally organized.</h1>
      <p class="max-w-2xl text-lg text-slate-300">
        Capture formulas with variables, notes, and examples. Keep favorites close, archive without loss, and return to concepts faster.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <AvButton href="/app">Open Formula Finder</AvButton>
      </div>
    </AvContainer>
  </section>

  <section>
    <AvContainer size="narrow" className="grid gap-5 py-14 sm:grid-cols-3">
      <article class="rounded-2xl border border-white/10 bg-slate-900/70 p-5">
        <h2 class="mb-2 text-lg font-medium text-white">Structured formula memory</h2>
        <p class="text-sm text-slate-300">Store expression, variable explanation, and short notes in one clean record.</p>
      </article>
      <article class="rounded-2xl border border-white/10 bg-slate-900/70 p-5">
        <h2 class="mb-2 text-lg font-medium text-white">Subject-first organization</h2>
        <p class="text-sm text-slate-300">Group by subject and topic so review sessions stay focused and calm.</p>
      </article>
      <article class="rounded-2xl border border-white/10 bg-slate-900/70 p-5">
        <h2 class="mb-2 text-lg font-medium text-white">Ansiversa connected</h2>
        <p class="text-sm text-slate-300">Dashboard summaries and high-signal milestones feed into the parent app.</p>
      </article>
    </AvContainer>
  </section>
</AppShell>
